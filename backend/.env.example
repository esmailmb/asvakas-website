# ── SMTP Credentials ───────────────────────────────────────────────
# Your outgoing mail server settings.
# Common providers:
#
#  Google Workspace (Gmail):       smtp.gmail.com  port 587   secure false
#  Outlook / Microsoft 365:        smtp.office365.com  port 587   secure false
#  Zoho Mail:                      smtp.zoho.com  port 587   secure false
#  GoDaddy / cPanel (smtpout):     smtpout.secureserver.net  port 465  secure true
#  Namecheap (Private Email):      mail.privateemail.com  port 587  secure false

SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@asvakas.com
SMTP_PASS=your_email_password_here

# ── Email destination ─────────────────────────────────────────────
TO_EMAIL=info@asvakas.com

# ── Front-end origin (your Netlify URL) ──────────────────────────
# Set this to your exact frontend domain to block requests from other sites.
# Examples:  https://asvakas.com  or  https://asvakas.netlify.app
ALLOWED_ORIGIN=https://asvakas.com
